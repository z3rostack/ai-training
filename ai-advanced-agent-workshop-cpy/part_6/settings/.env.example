# Copy to .env.dev and .env.prod, then fill in real values.
# APP_ENV (dev|prod) is read from the OS environment and selects which file loads;
# it defaults to dev.
#
# Per-task models and temperatures now live in config/tasks.yaml, not here.

OPEN_ROUTER_API_KEY="sk-or-v1-some-api-key"

# Postgres — required for the agent (SQLAlchemy async). NOT the publishable key.
# Project Settings -> Database -> password + connection string; use postgresql+asyncpg://
DATABASE_URL="postgresql+asyncpg://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# Embedding model for documents.reports vector search (must match stored vectors)
EMBEDDING_MODEL="openai/text-embedding-3-small"

SQL_RESULT_TRUNCATION=8000
SQL_MAX_LIMIT=100
SEARCH_LIMIT=5
LLM_MAX_RETRIES=2
HUMAN_REVIEW_MAX_RETRIES=3
LOG_LEVEL=DEBUG
